rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the logged-in user is Staff
    function isStaff() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // ReadyUp Events Collection
    match /events/{eventId} {
      allow read: if true;
      allow create, delete: if isStaff();

      allow update: if request.auth != null && (
        isStaff() || 
        (
          // Player "Join Queue" logic: ONLY the attendees field can change
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees']) &&
          request.resource.data.attendees.hasAll(resource.data.attendees) &&
          request.resource.data.attendees.size() == resource.data.attendees.size() + 1 &&
          request.auth.uid in request.resource.data.attendees
        )
      );
    }

    // ReadyUp Users Collection
    match /users/{userId} {
      allow read: if request.auth != null;
      
      // Allow users to create their profile, but NOT set their own role to 'staff'
      allow create: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.role == 'user';

      // Staff can update any user's profile (including role changes for promotion)
      // Regular users can update their own profile but NOT their role
      allow update: if request.auth != null && (
        isStaff() ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );
    }
  }
}
